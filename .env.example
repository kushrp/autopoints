# Amadeus Self-Service (free tier: 2000 calls/month)
# Sign up: https://developers.amadeus.com/register
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOSTNAME=test  # "test" for free tier, "production" for paid

# Cache location (defaults to ~/.autopoints/cache.db)
AUTOPOINTS_CACHE_PATH=

# CPP thresholds (cents per point)
AUTOPOINTS_CPP_GREAT=2.0
AUTOPOINTS_CPP_GOOD=1.5
