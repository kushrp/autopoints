# autopoints — DEPLOY-SIDE config (for scripts/deploy.sh).
# Copy to .env.deploy and fill in. Do NOT commit (.env.deploy is gitignored).
#
# This file describes WHERE to deploy. For WHAT to inject into the running
# containers, see the bottom of this file.

# ---- NAS access ----
NAS_HOST=192.168.1.42
NAS_USER=admin
NAS_SSH_PORT=22

# Absolute path on the NAS where compose files + .env will live.
# Synology: /volume1/docker/autopoints. UGREEN UGOS: usually /volume1/... too.
NAS_DEPLOY_DIR=/volume1/docker/autopoints

# ---- Portainer ----
# URL Portainer is reachable at from your Mac.
PORTAINER_URL=http://192.168.1.42:9000
# API token: in Portainer → top-right user icon → My account → Access tokens.
PORTAINER_API_KEY=
# Endpoint ID: in Portainer UI, click your environment; URL ends with /endpoints/<N>.
PORTAINER_ENDPOINT_ID=1

# ---- Image source ----
GHCR_IMAGE=ghcr.io/kushrp/autopoints:latest
# Set false if the GHCR package is private; then provide GHCR_USERNAME + GHCR_TOKEN below.
GHCR_PUBLIC=true
GHCR_USERNAME=
GHCR_TOKEN=

# ---- Runtime config injected into containers via .env on the NAS ----
# (These are the values .env.docker.example documents.)

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_NOTIFY_CHANNEL_ID=
DISCORD_RUN_INTERVAL_MINUTES=60
DISCORD_DEMO_MODE=

AUTOPOINTS_CPP_GREAT=2.0
AUTOPOINTS_CPP_GOOD=1.5
