# autopoints — Docker/NAS environment template.
# Copy to `.env` next to docker-compose.yml and fill in the values you have.
# You can leave any of these blank — the app degrades gracefully:
#  - no Discord token → discord container fails its healthcheck (harmless)
#
# Cash flight prices come from Google Flights automatically — no API key needed.

# --- Discord bot (optional) ---
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Optional: speeds slash-command sync from "up to 1 hour" to "instant"
# Right-click your server icon in Discord (Dev Mode on) → Copy ID
DISCORD_GUILD_ID=
# Optional: channel where watchlist auto-runs post new hits
DISCORD_NOTIFY_CHANNEL_ID=
# Optional: how often the bot re-runs every watchlist (minutes)
DISCORD_RUN_INTERVAL_MINUTES=60
# Optional: force the bot to use synthetic flight data
DISCORD_DEMO_MODE=

# --- CPP thresholds (optional) ---
AUTOPOINTS_CPP_GREAT=2.0
AUTOPOINTS_CPP_GOOD=1.5

# --- Timezone for Watchtower logs (optional) ---
TZ=UTC
